cat > simulation/tests/test_pod_dynamics.py <<'PYEOF'
"""Smoke tests for pod_dynamics.py."""

from simulation.src.pod_dynamics import VARIANTS


def test_three_variants_exist():
    assert set(VARIANTS.keys()) == {"H", "I", "B"}


def test_payload_fractions_in_range():
    for v_name, spec in VARIANTS.items():
        total = spec["dry_mass_kg"] + spec["cargo_mass_kg"]
        fraction = spec["cargo_mass_kg"] / total
        assert 0.15 < fraction < 0.85, f"variant {v_name} fraction {fraction} out of range"


def test_g_attenuation_matches_design():
    # Manna-H is unattenuated
    assert VARIANTS["H"]["internal_g"] >= VARIANTS["H"]["rail_accel_g"]
    # Manna-I attenuates ~5x
    assert VARIANTS["I"]["internal_g"] < VARIANTS["I"]["rail_accel_g"] / 4
    # Manna-B attenuates ~3x
    assert VARIANTS["B"]["internal_g"] < VARIANTS["B"]["rail_accel_g"] / 2.5
